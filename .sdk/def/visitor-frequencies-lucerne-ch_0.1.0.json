{
  "openapi": "3.0.3",
  "info": {
    "title": "Visitor Frequencies Lucerne (CH)",
    "description": "Live visitor frequencies in public spaces in Lucerne, Switzerland.",
    "version": "1.0.0",
    "contact": {
      "name": "OpenData Swiss",
      "url": "https://opendata.swiss/de/dataset/besucherfrequenzen-im-offentlichen-raum-api/resource/f5ee2f59-07fc-4142-b2be-416e3f4666eb"
    }
  },
  "servers": [
    {
      "url": "https://data.stadtluzern.ch",
      "description": "Production server"
    }
  ],
  "paths": {
    "/api/records/1.0/search/": {
      "get": {
        "summary": "Get visitor frequency data",
        "description": "Retrieve live visitor frequency data from public spaces in Lucerne, Switzerland.",
        "operationId": "getVisitorFrequencies",
        "parameters": [
          {
            "name": "dataset",
            "in": "query",
            "description": "Dataset identifier for visitor frequencies",
            "required": true,
            "schema": {
              "type": "string",
              "default": "besucherfrequenzen-im-offentlichen-raum"
            }
          },
          {
            "name": "rows",
            "in": "query",
            "description": "Number of records to return",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 10000
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Starting record number for pagination",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0,
              "minimum": 0
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort field and direction",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q",
            "in": "query",
            "description": "Full-text search query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "refine",
            "in": "query",
            "description": "Refine results by field values",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "exclude",
            "in": "query",
            "description": "Exclude results by field values",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Response format",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "csv",
                "xml"
              ],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with visitor frequency data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "nhits": {
                      "type": "integer",
                      "description": "Total number of records available"
                    },
                    "parameters": {
                      "type": "object",
                      "description": "Query parameters used for the request",
                      "properties": {
                        "dataset": {
                          "type": "string"
                        },
                        "rows": {
                          "type": "integer"
                        },
                        "start": {
                          "type": "integer"
                        },
                        "format": {
                          "type": "string"
                        }
                      }
                    },
                    "records": {
                      "type": "array",
                      "description": "Array of visitor frequency records",
                      "items": {
                        "type": "object",
                        "properties": {
                          "datasetid": {
                            "type": "string",
                            "description": "Dataset identifier"
                          },
                          "recordid": {
                            "type": "string",
                            "description": "Unique record identifier"
                          },
                          "fields": {
                            "type": "object",
                            "description": "Record data fields",
                            "properties": {
                              "timestamp": {
                                "type": "string",
                                "format": "date-time",
                                "description": "Timestamp of the measurement"
                              },
                              "location": {
                                "type": "string",
                                "description": "Location name in Lucerne"
                              },
                              "frequency": {
                                "type": "integer",
                                "description": "Visitor count"
                              },
                              "geopoint": {
                                "type": "array",
                                "description": "Geographic coordinates [lat, lon]",
                                "items": {
                                  "type": "number"
                                }
                              }
                            }
                          },
                          "geometry": {
                            "type": "object",
                            "description": "GeoJSON geometry object"
                          },
                          "record_timestamp": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Record creation timestamp"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - Invalid parameters"
          },
          "404": {
            "description": "Dataset not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {}
  },
  "tags": []
}
